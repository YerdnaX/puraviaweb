

  <main class="contenedor">
    <section class="seccion">
      <h1 class="titulo-seccion">Contacto</h1>
      <p class="subtitulo">Estamos listos para atenderte. Escríbenos o visítanos cuando quieras.</p>

      <div class="contacto-info">
        <div><strong>Dirección:</strong> Calle principal, barrio central, San José, Costa Rica. :D</div>
        <div><strong>Teléfono:</strong> +506 8888 0000</div>
        <div><strong>Correo:</strong> contacto@puravia.cr</div>
        <div><strong>Instagram:</strong> @puravia.cr</div>
        <div><strong>Horario:</strong> Lunes a sábado 7:00 a.m. - 9:00 p.m. | Domingo 8:00 a.m. - 5:00 p.m.</div>
      </div>

        <!-- Form de contacto  -->

      <form class="formulario">
        <div class="grid-formularios">
          <div class="campo">
            <label for="nombre">Nombre</label>
            <input id="nombre" type="text" placeholder="Nombre">
          </div>
          <div class="campo">
            <label for="correo">Correo</label>
            <input id="correo" type="email" placeholder="Correo electrónico">
          </div>
          <div class="campo">
            <label for="telefono">Teléfono</label>
            <input id="telefono" type="tel" placeholder="Ej. 8888-8888">
          </div>
          <div class="campo">
            <label for="asunto">Asunto</label>
            <input id="asunto" type="text" placeholder="Motivo del mensaje">
          </div>
        </div>
        <div class="campo">
          <label for="mensaje">Mensaje</label>
          <textarea id="mensaje" placeholder="Cuéntanos en qué podemos ayudarte"></textarea>
        </div>
        <div class="botones">
          <button class="btn" type="button">Enviar y ser contactado</button>
          <button class="btn btn-secundario" type="reset">Limpiar</button>
        </div>
      </form>
      <img src="images/logo-grande.png" alt="Logo PuraVia" style="width:400px; display:block; margin:0 auto 1.2rem;">
    </section>
  </main>















