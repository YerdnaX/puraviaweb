<main class="contenedor">
  <section class="seccion">
    <img src="images/logo-grande.png" alt="Logo PuraVia" style="width:220px; display:block; margin:0 auto 1.2rem;">
    <h1 class="titulo-seccion">Iniciar sesión</h1>
    <p class="subtitulo">Accede con tu usuario y contraseña. Selecciona tu tipo de perfil: cliente, mesero o administrador.</p>

    <form class="formulario" style="max-width:520px; margin:0 auto;">
      <div class="campo">
        <label for="usuario">Usuario o correo</label>
        <input id="usuario" type="text" placeholder="tu@correo.com o usuario">
      </div>
      <div class="campo">
        <label for="password">Contraseña</label>
        <input id="password" type="password" placeholder="Ingresa tu contraseña">
      </div>
      <div class="botones">
        <button class="btn" type="button">Entrar</button>
        <button class="btn btn-secundario" type="reset">Limpiar</button>
      </div>
    </form>
  </section>
</main>





