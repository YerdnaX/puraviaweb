
  <!-- Logo y slogan -->
  <main class="contenedor">
    <section class="hero">
      <div class="hero-texto">
        <img src="images/logo-grande.png" alt="Logo PuraVia" style="width:140px; margin-bottom:0.6rem;">
        <p class="estado estado-libre">Auténtico sabor tico</p>
        <h1>Bienvenido a PuraVia</h1>
        <p>Comida tradicional costarricense preparada con ingredientes frescos y el espíritu del pura vida. Desayunos típicos, platos caseros y bebidas naturales en un ambiente cálido.</p>
      </div>
      <div>
        <img src="images/portada-restaurante.png" alt="Restaurante PuraVia">
      </div>
    </section>

    <!-- sesion quienes somos -->
    <section class="seccion">
      <div class="banner">
        <div>
          <h2>¿Quiénes somos?</h2>
          <p>En PuraVia celebramos el auténtico sabor de Costa Rica. Somos un pequeño restaurante dedicado a recetas caseras, ingredientes frescos y la calidez de nuestra tierra.</p>
          <div class="botones">
            <a class="btn" href="/quienes-somos">Conócenos</a>
            <a class="btn btn-secundario" href="/contacto">Contáctenos</a>
          </div>
        </div>
        <img src="images/gallo-pinto.jpg" alt="Gallo pinto tradicional">
      </div>
    </section>

    <!-- Sabores destacados -->
    <section class="seccion">
      <h2 class="titulo-seccion">Sabores Destacados</h2>
      <p class="subtitulo">Prueba nuestros favoritos de la casa, preparados cada día con productos locales.</p>
      <div class="grid-productos">
        <article class="tarjeta tarjeta-producto">
          <img src="images/gallo-pinto.jpg" alt="Gallo pinto">
          <div class="detalles">
            <div class="texto">
              <h3>Gallo pinto con natilla</h3>
              <p>Clásico desayuno tico acompañado de huevos y plátano maduro.</p>
            </div>
            <span class="precio">₡3 200</span>
          </div>
        </article>
        <article class="tarjeta tarjeta-producto">
          <img src="images/casado.jpg" alt="Casado">
          <div class="detalles">
            <div class="texto">
              <h3>Casado tradicional</h3>
              <p>Arroz, frijoles, ensalada fresca, plátano y tu proteína favorita.</p>
            </div>
            <span class="precio">₡4 800</span>
          </div>
        </article>
        <article class="tarjeta tarjeta-producto">
          <img src="images/fresco-natural.jpg" alt="Bebida natural">
          <div class="detalles">
            <div class="texto">
              <h3>Frescos naturales</h3>
              <p>Bebidas frías de frutas tropicales sin conservantes.</p>
            </div>
            <span class="precio">₡1 400</span>
          </div>
        </article>
      </div>
    </section>
